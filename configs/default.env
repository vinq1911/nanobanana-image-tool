# Nano Banana Image Tool — Environment Configuration
#
# Copy this file to .env and adjust values as needed.

# Provider: "gemini" (Google Gemini API) or "falai" (fal.ai API)
NANOBANANA_PROVIDER=gemini

# --- Gemini provider settings ---

# Google Gemini API key. Also reads GEMINI_API_KEY and GOOGLE_API_KEY.
NANOBANANA_GEMINI_API_KEY=

# Gemini model ID for image generation.
# Default: gemini-2.5-flash-preview-image-generation
NANOBANANA_GEMINI_MODEL=gemini-2.5-flash-preview-image-generation

# --- fal.ai provider settings ---

# fal.ai API key. Also reads FAL_KEY.
NANOBANANA_FALAI_KEY=

# fal.ai model identifier.
# Default: fal-ai/nano-banana-2
NANOBANANA_FALAI_MODEL=fal-ai/nano-banana-2

# --- General settings ---

# Default output directory
NANOBANANA_OUTPUT_DIR=./output

# HTTP server settings
NANOBANANA_LISTEN_ADDR=0.0.0.0
NANOBANANA_PORT=8080

# Default image settings
NANOBANANA_DEFAULT_FORMAT=png
NANOBANANA_DEFAULT_WIDTH=1024
NANOBANANA_DEFAULT_HEIGHT=1024

# Logging
NANOBANANA_LOG_LEVEL=info
